{
  "name": "@bitfs/libbitfs",
  "version": "0.1.0",
  "description": "TypeScript client library for BitFS — mirrors libbitfs-go",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./method42": {
      "types": "./dist/method42/index.d.ts",
      "import": "./dist/method42/index.js"
    },
    "./wallet": {
      "types": "./dist/wallet/index.d.ts",
      "import": "./dist/wallet/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./metanet": {
      "types": "./dist/metanet/index.d.ts",
      "import": "./dist/metanet/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./tx": {
      "types": "./dist/tx/index.d.ts",
      "import": "./dist/tx/index.js"
    },
    "./spv": {
      "types": "./dist/spv/index.d.ts",
      "import": "./dist/spv/index.js"
    },
    "./network": {
      "types": "./dist/network/index.d.ts",
      "import": "./dist/network/index.js"
    },
    "./payment": {
      "types": "./dist/payment/index.d.ts",
      "import": "./dist/payment/index.js"
    },
    "./paymail": {
      "types": "./dist/paymail/index.d.ts",
      "import": "./dist/paymail/index.js"
    },
    "./revshare": {
      "types": "./dist/revshare/index.d.ts",
      "import": "./dist/revshare/index.js"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^1.7.0"
  },
  "peerDependencies": {
    "@bsv/sdk": "^2.0.5"
  },
  "peerDependenciesMeta": {
    "@bsv/sdk": { "optional": false }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": { "type": "git", "url": "https://github.com/bitfsorg/libbitfs-ts" },
  "keywords": ["bitfs", "bitcoin", "bsv", "encryption", "metanet", "method42"],
  "author": "BitFS Contributors",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://bitfs.org",
  "engines": { "node": ">=18" }
}
